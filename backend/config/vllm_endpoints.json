{
  "endpoints": [
    {
      "id": "deepseek",
      "label": "DeepSeek-OCR",
      "models": ["deepseek-ai/DeepSeek-OCR"],
      "host_env": "VLLM_DEEPSEEK_HOST",
      "default_host": "http://vllm-deepseek:8100",
      "compose_service": "vllm-deepseek",
      "gpu_device": 0,
      "port": 8100
    },
    {
      "id": "glm",
      "label": "GLM-OCR",
      "models": ["zai-org/GLM-OCR"],
      "host_env": "VLLM_GLM_HOST",
      "default_host": "http://vllm-glm:8101",
      "compose_service": "vllm-glm",
      "gpu_device": 1,
      "port": 8101
    },
    {
      "id": "lighton",
      "label": "LightOnOCR",
      "models": ["lightonai/LightOnOCR-2-1B"],
      "host_env": "VLLM_LIGHTON_HOST",
      "default_host": "http://vllm-lighton:8102",
      "compose_service": "vllm-lighton",
      "compose_profile": "lighton",
      "gpu_device": 1,
      "port": 8102,
      "speed_tier": "fast"
    },
    {
      "id": "chandra",
      "label": "Chandra OCR 2",
      "models": ["datalab-to/chandra-ocr-2"],
      "host_env": "VLLM_CHANDRA_HOST",
      "default_host": "http://vllm-chandra:8103",
      "compose_service": "vllm-chandra",
      "compose_profile": "chandra",
      "gpu_device": 1,
      "port": 8103,
      "speed_tier": "slow"
    }
  ]
}
