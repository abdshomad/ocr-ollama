# ----------------------------------------------------------------------------- paddleocr
# Upstream: https://github.com/PaddlePaddle/PaddleOCR
FROM ocr-base-cv AS paddleocr
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
        "paddlepaddle==3.3.0" \
        -i https://www.paddlepaddle.org.cn/packages/stable/cpu/
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
        "paddleocr>=2.7.3,<3" \
        "opencv-python-headless>=4.8.0,<5" \
        "uvicorn[standard]>=0.30.0" \
        "fastapi>=0.115.0" \
        "python-multipart>=0.0.9"
ENV PADDLEOCR_PORT=8260 \
    PADDLEOCR_MODEL_ID=paddleocr \
    PADDLEOCR_LANG=en \
    DISABLE_MODEL_SOURCE_CHECK=True
COPY docker/paddleocr/serve.py /opt/serve.py
WORKDIR /opt
EXPOSE 8260
CMD ["python", "/opt/serve.py"]

