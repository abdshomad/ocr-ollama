# syntax=docker/dockerfile:1.4
# Multi-target CPU OCR sidecars. Each service = compose `build.target`.
# Stages `ocr-base-cv` / `ocr-base-torch-cpu` mirror docker/Dockerfile.base-cv and
# docker/Dockerfile.base-torch-cpu — keep RUN blocks aligned when editing.

FROM python:3.12-slim-bookworm AS ocr-base-cv
ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
    && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libsm6 \
        libxcb1 \
        libxext6 \
        libxrender1 \
    && rm -rf /var/lib/apt/lists/*

FROM ocr-base-cv AS ocr-base-torch-cpu
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
        torch \
        torchvision \
        --index-url https://download.pytorch.org/whl/cpu

# ----------------------------------------------------------------------------- onnxtr
# Upstream: https://github.com/felixdittrich92/OnnxTR
FROM ocr-base-cv AS onnxtr
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
        "onnxtr[cpu]>=0.8.1,<0.9" \
        "uvicorn[standard]>=0.30.0" \
        "fastapi>=0.115.0" \
        "python-multipart>=0.0.9"
ENV ONNXTR_PORT=8230 \
    ONNXTR_MODEL_ID=onnxtr
COPY docker/onnxtr/serve.py /opt/serve.py
WORKDIR /opt
EXPOSE 8230
CMD ["python", "/opt/serve.py"]

