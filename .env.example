# Host port exposed by nginx (frontend + /api proxy)
PORT=3036

# Compose-built images (override to pull pre-built from your CR)
# BACKEND_IMAGE=ocr-ollama-backend:latest
# NGINX_IMAGE=ocr-ollama-nginx:latest
# CPU OCR base layers — profile `bases`: docker compose --profile bases build ocr-base-cv ocr-base-torch-cpu
# OCR_BASE_CV_IMAGE=ocr-ollama-base-cv:bookworm
# OCR_BASE_TORCH_CPU_IMAGE=ocr-ollama-base-torch-cpu:bookworm
# Ordered local build: docker buildx bake -f docker-bake.hcl cpu-sidecars

# Browser CORS when the UI origin is not localhost:5173 (split hosting, tunnel, second domain).
# Comma-separated exact origins (scheme + host + port if non-default). Empty string = no extra origins.
# CORS_ALLOW_ORIGINS=https://ocr.example.demoin.id,http://localhost:5173
# Optional subdomain wildcard (regex); see Starlette CORSMiddleware allow_origin_regex.
# CORS_ALLOW_ORIGIN_REGEX=https://.*\\.demoin\\.id(?::\\d+)?$

# Docker Compose project name (GPU page start/stop; default matches repo folder)
# COMPOSE_PROJECT_NAME=ocr-ollama
# Host absolute path to this repo (required for GPU page start/stop via backend + Docker socket)
# COMPOSE_HOST_PROJECT_DIR=/home/you/LABS/CPI/ocr-ollama

# Inference backend: vllm (default) or ollama
INFERENCE_BACKEND=vllm

# vLLM — two services (Run/Arena model picker shows both when healthy)
VLLM_DEEPSEEK_HOST=http://vllm-deepseek:8100
VLLM_GLM_HOST=http://vllm-glm:8101
VLLM_LIGHTON_HOST=http://vllm-lighton:8102
VLLM_CHANDRA_HOST=http://vllm-chandra:8103
VLLM_GEMMA4_HOST=http://vllm-gemma4:8104
VLLM_QWEN3_VL_HOST=http://vllm-qwen3-vl:8105
VLLM_HUNYUAN_OCR_HOST=http://vllm-hunyuanocr:8106
VLLM_PADDLEOCR_VL_HOST=http://vllm-paddleocr-vl:8107
VLLM_DOTS_MOCR_HOST=http://vllm-dotsmocr:8108
VLLM_PHI4_MM_HOST=http://vllm-phi4-mm:8109
MINERU_DIFFUSION_HOST=http://mineru-diffusion:8200
NEMOTRON_OCR_HOST=http://nemotron-ocr-v2:8210
RAPIDOCR_HOST=http://rapidocr:8220
ONNXTR_HOST=http://onnxtr:8230
EASYOCR_HOST=http://easyocr:8240
DOCTR_HOST=http://doctr:8250
PADDLEOCR_HOST=http://paddleocr:8260
DOCLING_HOST=http://docling:8270
LANYOCR_HOST=http://lanyocr:8280
VLLM_HOST=http://vllm-deepseek:8100

# Ollama API (when INFERENCE_BACKEND=ollama)
OLLAMA_HOST=http://host.docker.internal:11434

# vLLM containers (shared image; one model per container)
VLLM_IMAGE=vllm/vllm-openai:latest
# One GPU per service (defaults: DeepSeek GPU 0, GLM GPU 1)
VLLM_DEEPSEEK_CUDA_DEVICE=0
VLLM_GLM_CUDA_DEVICE=1
# LightOnOCR (~1B); compose profile `lighton` — stop GLM on same GPU if VRAM tight
VLLM_LIGHTON_CUDA_DEVICE=1
# Chandra OCR 2 (~4B); compose profile `chandra` — exclusive GPU recommended
VLLM_CHANDRA_CUDA_DEVICE=1
# VLLM_CHANDRA_MAX_MODEL_LEN=8192
# VLLM_CHANDRA_MAX_TOKENS=4096
# Gemma 4 E4B (~4.5B effective); compose profile `gemma4` — vLLM docs suggest ≥24 GB VRAM (BF16)
VLLM_GEMMA4_CUDA_DEVICE=1
# VLLM_GEMMA4_MAX_MODEL_LEN=8192
# VLLM_GEMMA4_MAX_TOKENS=4096
# Qwen3-VL Instruct (general VLM OCR); compose profile `qwen3vl` — stop GLM/LightOn/Chandra/Gemma4 on GPU 1 first
# VLLM_QWEN3_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
# VLLM_QWEN3_VL_CUDA_DEVICE=1
# VLLM_QWEN3_VL_MAX_MODEL_LEN=8192
# VLLM_QWEN3_VL_MAX_TOKENS=4096
# HunyuanOCR (~1B dedicated OCR VLM); compose profile `hunyuanocr` — vLLM recipe: greedy sampling; stop other GPU-1 vLLM services if VRAM tight
# VLLM_HUNYUAN_OCR_MODEL=tencent/HunyuanOCR
# VLLM_HUNYUAN_OCR_CUDA_DEVICE=1
# VLLM_HUNYUAN_OCR_MAX_TOKENS=8192
# PaddleOCR-VL (~0.9B dedicated OCR VLM); compose profile `paddleocr-vl` — needs vLLM with PaddleOCR-VL support (see issues/paddleocr-vl-vllm-integration.md)
# VLLM_PADDLEOCR_VL_MODEL=PaddlePaddle/PaddleOCR-VL
# VLLM_PADDLEOCR_VL_CUDA_DEVICE=1
# VLLM_PADDLEOCR_VL_GPU_MEMORY_UTIL=0.55
# VLLM_PADDLEOCR_VL_MAX_TOKENS=4096
# Dots.MOCR / dots.mocr (layout OCR VLM; vLLM ≥ 0.11); compose profile `dotsmocr` — see issues/dots-mocr-vllm-integration.md
# VLLM_DOTS_MOCR_MODEL=rednote-hilab/dots.mocr
# VLLM_DOTS_MOCR_CUDA_DEVICE=1
# VLLM_DOTS_MOCR_GPU_MEMORY_UTIL=0.55
# VLLM_DOTS_MOCR_MAX_MODEL_LEN=8192
# VLLM_DOTS_MOCR_MAX_TOKENS=8192
# If you pass --served-model-name to vLLM, set the OpenAI id here so chat + /api/models agree:
# VLLM_DOTS_MOCR_CHAT_MODEL=model
# Phi-4-multimodal-instruct (Microsoft multimodal VLM); compose profile `phi4mm` — trust-remote-code; see issues/phi4-multimodal-vllm-integration.md
# VLLM_PHI4_MM_MODEL=microsoft/Phi-4-multimodal-instruct
# VLLM_PHI4_MM_CUDA_DEVICE=1
# VLLM_PHI4_MM_GPU_MEMORY_UTIL=0.45
# VLLM_PHI4_MM_MAX_MODEL_LEN=8192
# VLLM_PHI4_MM_MAX_TOKENS=4096
# VLLM_PHI4_MM_CHAT_MODEL=model
# MinerU-Diffusion (2.5B nano_dvlm); compose profile `mineru` — needs an exclusive GPU
# Stop GLM/Lighton on the same device before starting (e.g. GPU 1: stop vllm-glm, vllm-lighton)
MINERU_DIFFUSION_CUDA_DEVICE=1
# Nemotron OCR v2 (PyTorch sidecar, not vLLM); compose profile `nemotron`
# NEMOTRON_VARIANT=multilingual
# NEMOTRON_VARIANT=english
NEMOTRON_OCR_CUDA_DEVICE=0
# RapidOCR (ONNX Runtime, CPU sidecar); compose profile `rapidocr`
# RAPIDOCR_IMAGE=ocr-ollama-rapidocr:latest
# OnnxTR (ONNX Runtime, CPU sidecar); compose profile `onnxtr`
# ONNXTR_IMAGE=ocr-ollama-onnxtr:latest
# EasyOCR (PyTorch CPU wheels in image; first run downloads CRAFT/recognition weights); compose profile `easyocr`
# EASYOCR_IMAGE=ocr-ollama-easyocr:latest
# docTR (PyTorch CPU; first run downloads detection/recognition weights); compose profile `doctr`
# DOCTR_IMAGE=ocr-ollama-doctr:latest
# PaddleOCR (PaddlePaddle CPU; first run downloads PP-OCR models); compose profile `paddleocr`
# PADDLEOCR_IMAGE=ocr-ollama-paddleocr:latest
# Docling (layout + OCR; PyTorch CPU; first run downloads HF layout + RapidOCR stack); compose profile `docling`
# DOCLING_IMAGE=ocr-ollama-docling:latest
# LanyOCR (ONNX + OpenCV; merges lines/rotations; first run may download ONNX weights); compose profile `lanyocr`
# LANYOCR_IMAGE=ocr-ollama-lanyocr:latest
# LANYOCR_MERGE_ROTATED=1
# LANYOCR_MERGE_VERTICAL=1
# LANYOCR_MERGE_BOXES_INFERENCE=1
# LANYOCR_USE_GPU=0
# PADDLEOCR_LANG=en
# PADDLEOCR_USE_GPU=0
# EASYOCR_LANGS=en
# EASYOCR_USE_GPU=0
# NEMOTRON_MERGE_LEVEL=paragraph
# NEMOTRON_SKIP_RELATIONAL=0
# NEMOTRON_OCR_IMAGE=ocr-ollama-nemotron-ocr-v2:latest
# MINERU_GPU_MEMORY_UTILIZATION=0.75
# MINERU_GPU_MEMORY_UTILIZATION=0.8
# MINERU_ENFORCE_EAGER=1
# MINERU_DIFFUSION_IMAGE=ocr-ollama-mineru-diffusion:latest
# VLLM_OCR_IMAGE=ocr-ollama-vllm-ocr:latest
# Per-GPU vLLM fraction (0.92 default — one OCR model per L40)
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_GLM_MAX_MODEL_LEN=8192
# VLLM_MTP_SPECULATIVE_TOKENS=1
# HUGGING_FACE_HUB_TOKEN=

# Optional host publish (docker-compose.vllm-publish.yml): 18100 / 18101

# Product scan: OCR model for text-only tier (two-step SKU / expiry extraction)
# DEFAULT_OCR_MODEL=deepseek-ai/DeepSeek-OCR

# Optional
# VLLM_TIMEOUT=600
# Backend: parallel /v1/models probes for /api/models (seconds; default 30 in code, 45 in docker-compose.yml)
# MODEL_LIST_HTTP_TIMEOUT=45
# MODEL_LIST_HTTP_TIMEOUT=5
# Seconds — HTTP timeout when probing inference for /api/models (offline endpoints fail fast)
# VLLM_MAX_TOKENS=2048
# OLLAMA_TIMEOUT=300
# MAX_IMAGE_BYTES=10485760
# LiteParse (lit CLI) — PDF / document text in backend; optional path override
# LITEPARSE_BIN=lit
# LITEPARSE_TIMEOUT=600
# OCR quality (Tesseract path): CLI default DPI is 150 — too soft vs GPU OCR; backend defaults to 300
# LITEPARSE_DPI=300
# LITEPARSE_OCR_LANGUAGE=en
# LiteParse OCR HTTP proxy (CLI --ocr-server-url); unset = bundled Tesseract
# LITEPARSE_OCR_SERVER_URL=http://host:8828/ocr
# LITEPARSE_PRESERVE_SMALL_TEXT=1
# Raw stdout instead of joining pages from JSON: LITEPARSE_FORMAT=text (default json)
