# Host port exposed by nginx (frontend + /api proxy)
PORT=3036

# Inference backend: vllm (default) or ollama
INFERENCE_BACKEND=vllm

# vLLM OpenAI API — use service name inside Compose; host port for curl from the machine
VLLM_HOST=http://vllm:8100
VLLM_PORT=8100

# Ollama API (when INFERENCE_BACKEND=ollama; runs on Docker host, not in this compose file)
OLLAMA_HOST=http://host.docker.internal:11434

# vLLM container image and model (first start downloads weights into volume vllm-hf-cache)
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL=deepseek-ai/DeepSeek-OCR
# HUGGING_FACE_HUB_TOKEN=

# Optional
# VLLM_TIMEOUT=600
# VLLM_MAX_TOKENS=8192
# OLLAMA_TIMEOUT=300
# MAX_IMAGE_BYTES=10485760
